<!-- UX REVAMP: post-item row layout (used on home + archive) -->
<a href="{{permalink}}" class="post-item">
  <div class="post-meta-col">
    <span class="post-date">{{publication.html}}</span>
    {{#readingTime}}<span class="post-readtime">{{readingTime}} min</span>{{/readingTime}}
    {{#tags}}<span class="post-tag">{{title}}</span>{{/tags}}
  </div>
  <div class="post-body-col">
    <h3 class="post-title">{{title}}</h3>
    <p class="post-excerpt">{{description}}</p>
  </div>
</a>

