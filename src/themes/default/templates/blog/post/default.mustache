{{<html}}
{{$main}}

<!-- UX REVAMP: article hero + full-width body -->
<article>
  <header class="article-hero">
    <div class="hero-inner">

      <p class="kicker">
        {{#page.tags}}<span class="kicker-tag">{{title}}</span>{{/page.tags}}
        <span class="kicker-date">{{page.publication.html}}</span>
      </p>

      <h1>{{page.title}}</h1>

      <p class="deck">{{page.description}}</p>

      <div class="byline-block">
        <div class="byline-meta">
          {{#page.authors}}
          <span class="byline-name">{{title}}</span>
          <span class="byline-role">Head of Product · happyapps</span>
          {{/page.authors}}
        </div>
        {{#page.readingTime}}<div class="byline-reading">{{page.readingTime}} min read</div>{{/page.readingTime}}
      </div>

    </div>
  </header>

  <div class="article-body">
    {{& page.contents}}
  </div>
</article>

