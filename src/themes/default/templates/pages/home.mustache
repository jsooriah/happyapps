{{<html}}
{{$main}}

<!-- UX REVAMP: hero + topics + post list + about strip -->

<section class="home-hero">
  <div class="home-hero-inner">

    <div class="hero-copy">
      <p class="hero-label">happyapps</p>
      <h1>Product &amp; Engineering<br><em>Intelligence</em></h1>
      <p class="hero-deck">
        Writing at the intersection of product management, AI engineering, and agile practice. Human-centric by design.
      </p>
      <div class="hero-actions">
        <a href="/happyapps/blog/posts/page/1" class="btn btn-primary">Read the archive</a>
        <a href="/happyapps/blog/posts/about-this-blog/" class="btn btn-secondary">About this blog</a>
      </div>
    </div>

    <!-- UPDATE this card when a new post becomes the featured one -->
    <div class="hero-feature">
      <p class="hero-feature-tag">Latest · JTBD Series</p>
      <h2>Why Your Best Growth Opportunity Isn't Asking for Anything</h2>
      <p>Most roadmaps are built on a structurally flawed input — the customers who engage most actively in discovery are rarely the customers who represent the largest growth opportunity.</p>
      <a href="/happyapps/blog/posts/why-your-best-growth-opportunity-isnt-asking-for-anything/" class="read-link">Read article</a>
    </div>

  </div>
</section>

<div class="topics-bar">
  <div class="topics-inner">
    <span class="topic-label">On</span>
    <a href="#" class="topic-chip">Product Management</a>
    <a href="#" class="topic-chip">Spec-Driven Development</a>
    <a href="#" class="topic-chip">AI Engineering</a>
    <a href="#" class="topic-chip">Jobs-to-be-Done</a>
    <a href="#" class="topic-chip">Graph Databases</a>
    <a href="#" class="topic-chip">Agile Practice</a>
    <a href="#" class="topic-chip">Agent Memory</a>
  </div>
</div>

<div class="posts-section">
  <div class="section-head">
    <span class="section-title">Recent writing</span>
    <a href="/happyapps/blog/posts/page/1" class="section-more">All posts</a>
  </div>
  <div class="post-list">
    {{#site.context.posts}}
    {{> partials.blog.post}}
    {{/site.context.posts}}
  </div>
</div>

<section class="about-strip">
  <div class="about-inner">
    <img class="about-avatar"
      src="/happyapps/assets/blog/authors/joel-sooriah/joel-sooriah.jpeg"
      alt="Joel Sooriah" width="80" height="80" />
    <div>
      <p class="about-name">Joel Sooriah</p>
      <p class="about-bio">Head of Product working at the intersection of trust &amp; safety infrastructure, AI agents, and regulatory compliance. Writing about building products and teams the human-centric way.</p>
      <div class="about-links">
        <a href="/happyapps/blog/posts/about-this-blog/">About this blog</a>
        <a href="https://github.com/jsooriah/" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.linkedin.com/in/jsooriah/" target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>
  </div>
</section>

